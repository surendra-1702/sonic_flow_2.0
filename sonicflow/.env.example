# ─────────────────────────────────────────────
# SonicFlow Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sonicflow?retryWrites=true&w=majority

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=replace_with_your_random_64_char_hex_string

# Cloudinary
CLOUDINARY_CLOUD_NAME=dxhlh9xfn

# App
CLIENT_URL=http://localhost:5000
NODE_ENV=development
PORT=5000

# Songs file path (relative to project root or absolute)
SONGS_URL_PATH=songs.url
